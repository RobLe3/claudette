# Ultipa GraphDB Configuration - DO NOT COMMIT TO REPOSITORY
ULTIPA_ENDPOINT=<url>
ULTIPA_ACCESS_TOKEN=<api-key>
ULTIPA_DATABASE=claudette_metacognitive
ULTIPA_GRAPH=problem_solving_graph

# Connection settings
ULTIPA_TIMEOUT=30000
ULTIPA_MAX_RETRIES=3
ULTIPA_RETRY_DELAY=1000

# Performance settings
ULTIPA_BATCH_SIZE=1000
ULTIPA_QUERY_CACHE_SIZE=100
ULTIPA_CONNECTION_POOL_SIZE=5
