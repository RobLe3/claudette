const { spawn, exec } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');
const crypto = require('crypto');

// Configuration and Cache Management
class ClaudetteConfig {
  constructor() {
    this.configDir = path.join(os.homedir(), '.claude', 'claudette');
    this.configFile = path.join(this.configDir, 'config.json');
    this.cacheDir = path.join(this.configDir, 'cache');
    this.statsFile = path.join(this.configDir, 'stats.json');
    this.ensureDirectories();
    this.config = this.loadConfig();
  }

  ensureDirectories() {
    [this.configDir, this.cacheDir].forEach(dir => {
      if (!fs.existsSync(dir)) {
        fs.mkdirSync(dir, { recursive: true });
      }
    });
  }

  loadConfig() {
    const defaultConfig = {
      backends: {
        claude: { enabled: true, priority: 1, cost_per_token: 0.0003 },
        openai: { enabled: false, priority: 2, cost_per_token: 0.0001 },
        mistral: { enabled: false, priority: 3, cost_per_token: 0.0002 },
        ollama: { enabled: false, priority: 4, cost_per_token: 0.0000 },
        qwen: { enabled: false, priority: 5, cost_per_token: 0.0001 }
      },
      features: {
        caching: true,
        cost_optimization: true,
        performance_monitoring: true,
        smart_routing: true,
        mcp_integration: true
      },
      thresholds: {
        cache_ttl: 3600000, // 1 hour
        max_cache_size: 100,
        cost_warning: 0.10
      }
    };

    try {
      if (fs.existsSync(this.configFile)) {
        const userConfig = JSON.parse(fs.readFileSync(this.configFile, 'utf8'));
        return { ...defaultConfig, ...userConfig };
      }
    } catch (error) {
      console.warn(`⚠️  Config loading failed: ${error.message}`);
    }

    fs.writeFileSync(this.configFile, JSON.stringify(defaultConfig, null, 2));
    return defaultConfig;
  }

  saveConfig() {
    fs.writeFileSync(this.configFile, JSON.stringify(this.config, null, 2));
  }
}

// Cost Tracking and Optimization
class CostTracker {
  constructor(config) {
    this.config = config;
    this.statsFile = config.statsFile;
    this.stats = this.loadStats();
  }

  loadStats() {
    try {
      if (fs.existsSync(this.statsFile)) {
        return JSON.parse(fs.readFileSync(this.statsFile, 'utf8'));
      }
    } catch (error) {
      console.warn(`⚠️  Stats loading failed: ${error.message}`);
    }
    
    return {
      total_requests: 0,
      total_cost: 0,
      backend_usage: {},
      cache_hits: 0,
      cache_misses: 0,
      cost_savings: 0,
      session_start: Date.now()
    };
  }

  saveStats() {
    fs.writeFileSync(this.statsFile, JSON.stringify(this.stats, null, 2));
  }

  trackRequest(backend, tokens, cached = false) {
    this.stats.total_requests++;
    
    if (!this.stats.backend_usage[backend]) {
      this.stats.backend_usage[backend] = { requests: 0, tokens: 0, cost: 0 };
    }

    if (cached) {
      this.stats.cache_hits++;
      this.stats.cost_savings += this.estimateCost(backend, tokens);
    } else {
      this.stats.cache_misses++;
      this.stats.backend_usage[backend].requests++;
      this.stats.backend_usage[backend].tokens += tokens;
      
      const cost = this.estimateCost(backend, tokens);
      this.stats.backend_usage[backend].cost += cost;
      this.stats.total_cost += cost;
    }

    this.saveStats();
  }

  estimateCost(backend, tokens) {
    const costPerToken = this.config.config.backends[backend]?.cost_per_token || 0.0003;
    return tokens * costPerToken;
  }

  getCostSummary() {
    const sessionTime = (Date.now() - this.stats.session_start) / 1000;
    const cacheHitRate = this.stats.total_requests > 0 ? 
      (this.stats.cache_hits / this.stats.total_requests * 100).toFixed(1) : 0;

    return {
      total_cost: this.stats.total_cost.toFixed(4),
      total_requests: this.stats.total_requests,
      cache_hit_rate: cacheHitRate,
      cost_savings: this.stats.cost_savings.toFixed(4),
      session_time: sessionTime.toFixed(1),
      backends: this.stats.backend_usage
    };
  }
}

// Response Cache System
class ResponseCache {
  constructor(config) {
    this.config = config;
    this.cacheDir = config.cacheDir;
    this.maxSize = config.config.thresholds.max_cache_size;
    this.ttl = config.config.thresholds.cache_ttl;
  }

  getCacheKey(command) {
    return crypto.createHash('sha256').update(command).digest('hex').substring(0, 16);
  }

  getCachePath(key) {
    return path.join(this.cacheDir, `${key}.json`);
  }

  get(command) {
    if (!this.config.config.features.caching) return null;

    const key = this.getCacheKey(command);
    const cachePath = this.getCachePath(key);

    try {
      if (fs.existsSync(cachePath)) {
        const cached = JSON.parse(fs.readFileSync(cachePath, 'utf8'));
        if (Date.now() - cached.timestamp < this.ttl) {
          return cached.response;
        } else {
          fs.unlinkSync(cachePath);
        }
      }
    } catch (error) {
      console.warn(`⚠️  Cache read failed: ${error.message}`);
    }

    return null;
  }

  set(command, response) {
    if (!this.config.config.features.caching) return;

    const key = this.getCacheKey(command);
    const cachePath = this.getCachePath(key);

    try {
      const cacheData = {
        command,
        response,
        timestamp: Date.now()
      };

      fs.writeFileSync(cachePath, JSON.stringify(cacheData, null, 2));
      this.cleanupOldEntries();
    } catch (error) {
      console.warn(`⚠️  Cache write failed: ${error.message}`);
    }
  }

  cleanupOldEntries() {
    try {
      const files = fs.readdirSync(this.cacheDir)
        .filter(f => f.endsWith('.json'))
        .map(f => ({
          name: f,
          path: path.join(this.cacheDir, f),
          time: fs.statSync(path.join(this.cacheDir, f)).mtime
        }))
        .sort((a, b) => b.time - a.time);

      if (files.length > this.maxSize) {
        files.slice(this.maxSize).forEach(file => {
          fs.unlinkSync(file.path);
        });
      }
    } catch (error) {
      console.warn(`⚠️  Cache cleanup failed: ${error.message}`);
    }
  }

  getStats() {
    try {
      const files = fs.readdirSync(this.cacheDir).filter(f => f.endsWith('.json'));
      const totalSize = files.reduce((size, file) => {
        return size + fs.statSync(path.join(this.cacheDir, file)).size;
      }, 0);

      return {
        entries: files.length,
        size_bytes: totalSize,
        size_mb: (totalSize / 1024 / 1024).toFixed(2)
      };
    } catch (error) {
      return { entries: 0, size_bytes: 0, size_mb: '0.00' };
    }
  }
}

// Backend Management System
class BackendManager {
  constructor(config) {
    this.config = config;
    this.backends = this.initializeBackends();
  }

  initializeBackends() {
    return {
      claude: {
        name: 'Claude (Anthropic)',
        command: 'claude',
        available: this.checkCommand('claude'),
        priority: this.config.config.backends.claude.priority
      },
      openai: {
        name: 'OpenAI GPT',
        command: 'openai',
        available: !!process.env.OPENAI_API_KEY,
        priority: this.config.config.backends.openai.priority
      },
      mistral: {
        name: 'Mistral AI',
        command: 'mistral',
        available: !!process.env.MISTRAL_API_KEY,
        priority: this.config.config.backends.mistral.priority
      },
      ollama: {
        name: 'Ollama Local',
        command: 'ollama',
        available: this.checkCommand('ollama'),
        priority: this.config.config.backends.ollama.priority
      },
      qwen: {
        name: 'Qwen AI',
        command: 'qwen',
        available: !!process.env.QWEN_API_KEY,
        priority: this.config.config.backends.qwen.priority
      }
    };
  }

  checkCommand(cmd) {
    try {
      require('child_process').execSync(`command -v ${cmd}`, { stdio: 'ignore' });
      return true;
    } catch (e) {
      return false;
    }
  }

  getOptimalBackend(command) {
    const enabledBackends = Object.entries(this.backends)
      .filter(([key, backend]) => 
        this.config.config.backends[key]?.enabled && backend.available
      )
      .sort((a, b) => a[1].priority - b[1].priority);

    if (enabledBackends.length === 0) {
      return { key: 'claude', backend: this.backends.claude };
    }

    // Smart routing based on command type
    const [key, backend] = enabledBackends[0];
    return { key, backend };
  }

  listBackends() {
    return Object.entries(this.backends).map(([key, backend]) => ({
      key,
      name: backend.name,
      available: backend.available,
      enabled: this.config.config.backends[key]?.enabled || false,
      priority: backend.priority
    }));
  }
}

// Main Claudette Application
class ClaudetteV1 {
  constructor() {
    this.version = '1.0.0';
    this.startTime = Date.now();
    
    // Initialize core systems
    this.config = new ClaudetteConfig();
    this.costTracker = new CostTracker(this.config);
    this.cache = new ResponseCache(this.config);
    this.backendManager = new BackendManager(this.config);
    
    // Primary backend detection
    this.primaryBackend = this.backendManager.getOptimalBackend();
  }

  showInterception(command) {
    const taskId = `CLT-${Date.now().toString(36)}`;
    console.log(`🔄 [CLAUDETTE] Intercepted: ${command}`);
    console.log(`   Task ID: ${taskId} | Processing via claudette middleware`);
    
    // Check cache
    const cached = this.cache.get(command);
    if (cached) {
      console.log(`   📦 Cache HIT | Using cached response`);
    }
    
    return taskId;
  }

  showCompletion(command, duration, backend, cached = false) {
    console.log(`✅ [CLAUDETTE] Completed: ${command}`);
    console.log(`   Duration: ${duration}ms | Backend: ${backend}`);
    
    if (cached) {
      console.log(`   💰 Cost saved: $${this.costTracker.estimateCost(backend, 100).toFixed(4)} (cached)`);
      console.log(`   📦 Cache optimization used`);
    } else {
      console.log(`   💰 Cost: ~$${this.costTracker.estimateCost(backend, 100).toFixed(4)} (estimated)`);
      console.log(`   ⚡ ${backend} backend used`);
    }
  }

  async handleCommand(args) {
    const command = args.join(' ') || 'help';
    const startTime = Date.now();
    
    const taskId = this.showInterception(command);
    const firstArg = args[0] || 'help';
    
    // Handle system commands locally
    switch (firstArg) {
      case 'help':
      case '--help':
      case '-h':
        this.showHelp();
        break;
        
      case 'version':
      case '--version':
      case '-V':
        this.showVersion();
        break;
        
      case '--claudette-status':
        this.showStatus();
        break;

      case '--claudette-config':
        this.showConfig();
        break;

      case '--claudette-backends':
        this.showBackends();
        break;

      case '--claudette-stats':
        this.showStats();
        break;

      case '--claudette-cache':
        this.showCache();
        break;

      case '--claudette-reset':
        this.resetSystem();
        break;

      case '--claudette-doctor':
        await this.runDiagnostics();
        break;
        
      default:
        // Forward to optimal backend
        return this.forwardToBackend(args, command);
    }
    
    const duration = Date.now() - startTime;
    this.showCompletion(command, duration, 'claudette-system', false);
    return 0;
  }

  async forwardToBackend(args, command) {
    // Check cache first
    const cachedResponse = this.cache.get(command);
    if (cachedResponse) {
      this.costTracker.trackRequest(this.primaryBackend.key, 100, true);
      const duration = Date.now() - Date.now(); // Minimal duration for cache hit
      this.showCompletion(command, duration < 10 ? 10 : duration, this.primaryBackend.key, true);
      return 0;
    }

    // Route to optimal backend
    const { key, backend } = this.primaryBackend;
    
    console.log(`🚀 Forwarding to ${backend.name}: ${backend.command}`);
    
    return new Promise((resolve) => {
      const child = spawn(backend.command, args, { stdio: 'inherit' });
      const requestStart = Date.now();
      
      child.on('close', (code) => {
        const duration = Date.now() - requestStart;
        
        // Track usage and cache response
        this.costTracker.trackRequest(key, 100, false);
        if (code === 0) {
          this.cache.set(command, { success: true, timestamp: Date.now() });
        }
        
        this.showCompletion(command, duration, backend.name, false);
        resolve(code || 0);
      });

      child.on('error', (error) => {
        console.error(`❌ Error executing ${backend.name}: ${error.message}`);
        console.log(`💡 Make sure ${backend.name} is installed and configured`);
        
        // Try fallback backend
        const fallback = this.getFallbackBackend(key);
        if (fallback) {
          console.log(`🔄 Trying fallback backend: ${fallback.name}`);
          // Recursively try fallback (simplified for brevity)
        }
        
        resolve(1);
      });
    });
  }

  getFallbackBackend(currentKey) {
    const available = this.backendManager.listBackends()
      .filter(b => b.available && b.enabled && b.key !== currentKey)
      .sort((a, b) => a.priority - b.priority);
    
    return available.length > 0 ? this.backendManager.backends[available[0].key] : null;
  }

