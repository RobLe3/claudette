{
  "name": "claudette",
  "version": "2.1.6",
  "description": "High-performance Claude Code middleware with RAG integration and AI backend manager",
  "main": "claudette",
  "bin": {
    "claudette": "./claudette"
  },
  "scripts": {
    "start": "./claudette",
    "build": "tsc",
    "test": "npm run build && node src/test/claudette-unit-tests.js",
    "test:rag": "node src/test/rag-integration-tests.js",
    "test:all": "npm run test && npm run test:rag",
    "test:kpi": "node src/test/kpi-framework.js",
    "test:quality": "node src/test/qwen-code-quality.js",
    "test:direct": "node src/test/qwen-direct.js",
    "test:fresh-system": "node src/test/integration/fresh-system-validator.js",
    "test:performance": "node src/test/regression/performance-benchmarker.js",
    "test:e2e": "node src/test/e2e/user-journey-validator.js",
    "test:analytics": "node src/test/analytics/success-rate-analytics.js",
    "test:emergency": "node src/test/validation/emergency-release-validator.js",
    "test:validation": "npm run test:validation:quick",
    "test:validation:quick": "npm run test:fresh-system && npm run test:e2e && npm run test:emergency",
    "test:validation:full": "npm run test && npm run test:rag && npm run test:fresh-system && npm run test:performance && npm run test:e2e && npm run test:analytics && npm run test:emergency",
    "test:validation:emergency": "npm run test:validation:quick --emergency",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "validate": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm run test:validation:full",
    "prepack": "npm run build",
    "release": "scripts/emergency-release.sh",
    "release:emergency": "scripts/emergency-release.sh --emergency",
    "release:dry-run": "scripts/emergency-release.sh --dry-run",
    "validate:artifacts": "scripts/validate-artifacts.sh",
    "install": "scripts/install.sh",
    "install:windows": "scripts/install/install-windows.ps1",
    "install:unix": "scripts/install/install-unix.sh",
    "setup": "./claudette init",
    "setup:quick": "./claudette init --quick",
    "setup:wizard": "./claudette setup init",
    "setup:validate": "./claudette setup validate",
    "setup-credentials": "node -e \"require('./src/credentials').getCredentialManager().then(m => console.log('Use: claudette setup-credentials'))\""
  },
  "keywords": [
    "claude",
    "middleware",
    "ai",
    "claude-code",
    "task-interception",
    "cost-optimization",
    "rag",
    "graphrag",
    "vector-db",
    "lightrag",
    "mcp",
    "docker",
    "retrieval-augmented-generation"
  ],
  "author": "Claudette Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/user/claudette.git"
  },
  "bugs": {
    "url": "https://github.com/user/claudette/issues"
  },
  "homepage": "https://github.com/user/claudette#readme",
  "files": [
    "dist/**/*",
    "claudette",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@types/sqlite3": "^3.1.11",
    "better-sqlite3": "^12.2.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^5.11.0",
    "ora": "^8.2.0",
    "sqlite3": "^5.1.7"
  }
}
