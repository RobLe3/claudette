{
  "name": "@claudette/nodejs-migration",
  "version": "1.0.0",
  "description": "Claudette - High-performance Claude Code middleware and AI backend manager",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claudette-node": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "start": "node dist/cli/index.js",
    "benchmark": "node scripts/benchmark.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.20.0",
    "axios": "^1.6.0",
    "node-fetch": "^3.3.2",
    "commander": "^11.1.0",
    "js-yaml": "^4.1.0",
    "better-sqlite3": "^9.2.0",
    "winston": "^3.11.0",
    "tiktoken": "^1.0.10",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "zod": "^3.22.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.8",
    "@types/better-sqlite3": "^7.6.8",
    "@types/lodash": "^4.14.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0"
  }
}